<Window x:Class="WPF_projo.EventDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły Wydarzenia" Height="700" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip" MinHeight="600" MinWidth="400">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F6FA">
        <StackPanel Margin="20">
            <TextBlock Text="Karta wydarzenia" FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <!-- ===== POLA GŁÓWNE (edytowalne w trybie edycji) ===== -->
            <TextBlock Text="Tytuł:" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="DetailsTitle"
                     Text="{Binding Event.Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                     IsReadOnly="{Binding IsReadOnly}" Height="30" Padding="5" Margin="0,0,0,2"/>
            <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                       Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DetailsTitle}"/>

            <TextBlock Text="Data (dd.MM.yyyy):" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="DetailsDate"
                     Text="{Binding Event.Date, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                     IsReadOnly="{Binding IsReadOnly}" Height="30" Padding="5" Margin="0,0,0,2"/>
            <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                       Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DetailsDate}"/>

            <TextBlock Text="Kategoria:" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Height="30" Margin="0,0,0,10"
                      ItemsSource="{Binding FormCategories}"
                      SelectedItem="{Binding Event.Category}"
                      IsEnabled="{Binding IsEditing}"/>

            <TextBlock Text="Opis:" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="DetailsDesc"
                     Text="{Binding Event.ShortDescription, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"
                     IsReadOnly="{Binding IsReadOnly}" Height="80" Padding="5"
                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,2"/>
            <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,15"
                       Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DetailsDesc}"/>

            <!-- Tryb podglądu: Edytuj + Zamknij -->
            <Grid Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Edytuj" Height="40" Margin="0,0,5,0"
                        Background="#F39C12" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Command="{Binding EditCommand}"/>
                <Button Grid.Column="1" Content="Zamknij" Height="40" Margin="5,0,0,0"
                        Background="#95A5A6" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Command="{Binding CloseCommand}"/>
            </Grid>

            <!-- Tryb edycji: Zapisz + Anuluj -->
            <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Zapisz" Height="40" Margin="0,0,5,0"
                        Background="#27AE60" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Command="{Binding SaveCommand}"/>
                <Button Grid.Column="1" Content="Anuluj" Height="40" Margin="5,0,0,0"
                        Background="#E74C3C" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Command="{Binding CancelCommand}"/>
            </Grid>

            <Separator Margin="0,0,0,15"/>

            <!-- ===== OCENA ===== -->
            <TextBlock Text="Moja ocena:" Foreground="#34495E" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <ComboBox Height="32" Margin="0,0,0,15"
                      ItemsSource="{Binding RatingOptions}"
                      SelectedItem="{Binding SelectedRating}"/>

            <!-- ===== UCZESTNICTWO ===== -->
            <CheckBox Content="Byłem/am na tym wydarzeniu"
                      IsChecked="{Binding IsAttended}"
                      Margin="0,0,0,15" FontWeight="SemiBold" Foreground="#34495E"
                      Cursor="Hand" FontSize="13"/>

            <Separator Margin="0,0,0,15"/>

            <!-- ===== KOMENTARZE ===== -->
            <TextBlock Text="Komentarze:" Foreground="#34495E" Margin="0,0,0,8" FontWeight="SemiBold"/>

            <ItemsControl ItemsSource="{Binding Comments}" Margin="0,0,0,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1"
                                CornerRadius="3" Padding="10,7" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                           Foreground="#2C3E50" Grid.Column="0" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="✕" Background="Transparent"
                                        BorderThickness="0" Foreground="#E74C3C" FontWeight="Bold"
                                        Cursor="Hand" Margin="8,0,0,0" VerticalAlignment="Center"
                                        Command="{Binding DataContext.DeleteCommentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Dodaj komentarz -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NewComment, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Margin="0,0,8,0" ToolTip="Wpisz komentarz..."/>
                <Button Grid.Column="1" Content="Dodaj" Height="35"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding AddCommentCommand}"/>
            </Grid>

            <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="#95A5A6"
                       Text="Komentarze i ocena są zapisywane natychmiast."/>
        </StackPanel>
    </ScrollViewer>
</Window>
