<Window x:Class="WPF_projo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moje Wydarzenia" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Grid Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="Moje Wydarzenia" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="— osobisty planer eventów" Foreground="White"
                           FontSize="14" VerticalAlignment="Center" Margin="10,2,0,0" Opacity="0.8"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Lewa kolumna: filtry + zakładki -->
            <Grid Grid.Column="0" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Pasek filtrów i sortowania -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" VerticalContentAlignment="Center"
                                 ToolTip="Szukaj po tytule lub opisie"/>
                        <ComboBox Grid.Column="1" Width="140" Margin="10,0,0,0" Height="30"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"/>
                        <ComboBox Grid.Column="2" Width="145" Margin="10,0,0,0" Height="30"
                                  ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSort}"/>
                        <Button Grid.Column="3" Width="42" Height="30" Margin="8,0,0,0"
                                Content="{Binding SortDirectionLabel}" FontSize="16"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding ToggleSortDirectionCommand}"
                                ToolTip="Zmień kierunek sortowania"/>
                    </Grid>
                </Border>

                <!-- Zakładki: Nadchodzące / Historia -->
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0"
                            BorderBrush="#BDC3C7">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="Foreground" Value="#7F8C8D"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <!-- Zakładka: Nadchodzące -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Nadchodzące"/>
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="10"
                                        Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UpcomingCount}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <ItemsControl ItemsSource="{Binding UpcomingView}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="Black"/>
                                                        <Border Background="#ECF0F1" Padding="8,2" Margin="10,2,0,0"
                                                                VerticalAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1">
                                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Black"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Date}" FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding ShortDescription}" TextWrapping="Wrap"
                                                               Foreground="#555" Margin="0,3,0,0" MaxHeight="40"/>
                                                    <TextBlock FontSize="12" Foreground="#E67E22" Margin="0,4,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Rating}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="Ocena: "/>
                                                        <Run Text="{Binding Rating, StringFormat={}{0}/5}"/>
                                                        <Run Text=" ★"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="95">
                                                    <Button Content="Szczegóły" Height="30" Style="{StaticResource WarningButton}" Margin="0,0,0,5"
                                                            Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Byłem tutaj!" Height="30" Style="{StaticResource AccentButton}" Margin="0,0,0,5"
                                                            Command="{Binding DataContext.MarkAttendedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Usuń" Height="30" Style="{StaticResource DangerButton}"
                                                            Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Zakładka: Historia -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Historia"/>
                                <Border Background="{StaticResource SuccessBrush}" CornerRadius="10"
                                        Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding HistoryCount}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <ItemsControl ItemsSource="{Binding HistoryView}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10"
                                                BorderBrush="#A8E6CF" Background="#F0FFF4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✓" FontSize="14" Foreground="{StaticResource SuccessBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="Black"/>
                                                        <Border Background="#ECF0F1" Padding="8,2" Margin="10,2,0,0"
                                                                VerticalAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1">
                                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Black"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Date}" FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding ShortDescription}" TextWrapping="Wrap"
                                                               Foreground="#555" Margin="0,3,0,0" MaxHeight="40"/>
                                                    <TextBlock FontSize="12" Foreground="#E67E22" Margin="0,4,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Rating}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="Ocena: "/>
                                                        <Run Text="{Binding Rating, StringFormat={}{0}/5}"/>
                                                        <Run Text=" ★"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="95">
                                                    <Button Content="Szczegóły" Height="30" Style="{StaticResource WarningButton}" Margin="0,0,0,5"
                                                            Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Wróć" Height="30" Style="{StaticResource MutedButton}" Margin="0,0,0,5"
                                                            Command="{Binding DataContext.MarkAttendedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Usuń" Height="30" Style="{StaticResource DangerButton}"
                                                            Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Prawa kolumna: formularz -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,20,20,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Dodaj wydarzenie" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,0,20"/>

                    <TextBlock Text="Tytuł:" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="TitleErrSource" Text="{Binding NewEvent.Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="30" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TitleErrSource}"/>

                    <TextBlock Text="Data (dd.MM.yyyy):" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="DateErrSource" Text="{Binding NewEvent.Date, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="30" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DateErrSource}"/>

                    <TextBlock Text="Kategoria:" Foreground="Black" Margin="0,0,0,5"/>
                    <ComboBox Height="30" Margin="0,0,0,10"
                              ItemsSource="{Binding FormCategories}"
                              SelectedItem="{Binding NewEvent.Category}"/>

                    <TextBlock Text="Krótki opis:" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="DescErrSource" Text="{Binding NewEvent.ShortDescription, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DescErrSource}"/>

                    <Button Content="Dodaj" Height="40" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddEventCommand}" Margin="0,0,0,8"/>
                    <Button Content="Wyczyść" Height="32" Style="{StaticResource MutedButton}"
                            Command="{Binding ClearFormCommand}"/>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="Black"
                               TextWrapping="Wrap" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>


    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Grid Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="WPF-projo" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="— System Zarządzania Domem Kultury" Foreground="White"
                           FontSize="14" VerticalAlignment="Center" Margin="10,2,0,0"/>
            </StackPanel>
            <Button Content="{Binding AuthButtonText}" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" Width="120" Height="35" Margin="0,0,20,0"
                    Command="{Binding AuthCommand}"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Lewa kolumna: filtry + lista -->
            <Grid Grid.Column="0" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tytuł + licznik -->
                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" Text="Wydarzenia" FontSize="20" FontWeight="SemiBold" Foreground="Black"/>
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="Black">
                        <Run Text="Łącznie: "/>
                        <Run Text="{Binding EventsCount, Mode=OneWay}"/>
                    </TextBlock>
                </DockPanel>

                <!-- Pasek filtrów -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" VerticalContentAlignment="Center"
                                 ToolTip="Szukaj po tytule lub opisie"/>
                        <ComboBox Grid.Column="1" Width="140" Margin="10,0,0,0" Height="30"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"/>
                        <ComboBox Grid.Column="2" Width="150" Margin="10,0,0,0" Height="30"
                                  ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSort}"/>
                    </Grid>
                </Border>

                <!-- Lista -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding EventsView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                                <Border Background="#ECF0F1" CornerRadius="0" Padding="8,2" Margin="10,2,0,0" VerticalAlignment="Center"
                                                        BorderBrush="#BDC3C7" BorderThickness="1">
                                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Black"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Date}" FontSize="13" Foreground="Black" Margin="0,4,0,4"/>
                                            <TextBlock Text="{Binding ShortDescription}" TextWrapping="Wrap" Foreground="Black"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" Content="Szczegóły" Width="90" Height="34"
                                                Style="{StaticResource WarningButton}" VerticalAlignment="Center" Margin="0,0,8,0"
                                                Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Grid.Column="2" Content="Usuń" Width="80" Height="34"
                                                Style="{StaticResource DangerButton}" VerticalAlignment="Center"
                                                Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Prawa kolumna: formularz -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,20,20,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Dodaj wydarzenie" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,0,20"/>

                    <TextBlock Text="Tytuł:" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="TitleErrSource" Text="{Binding NewEvent.Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="30" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TitleErrSource}"/>

                    <TextBlock Text="Data (dd.MM.yyyy):" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="DateErrSource" Text="{Binding NewEvent.Date, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="30" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DateErrSource}"/>

                    <TextBlock Text="Kategoria:" Foreground="Black" Margin="0,0,0,5"/>
                    <ComboBox Height="30" Margin="0,0,0,10"
                              ItemsSource="{Binding FormCategories}"
                              SelectedItem="{Binding NewEvent.Category}"/>

                    <TextBlock Text="Krótki opis:" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="DescErrSource" Text="{Binding NewEvent.ShortDescription, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DescErrSource}"/>

                    <Button Content="Dodaj" Height="40" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddEventCommand}" Margin="0,0,0,8"/>
                    <Button Content="Wyczyść" Height="32" Style="{StaticResource MutedButton}"
                            Command="{Binding ClearFormCommand}"/>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="Black"
                               TextWrapping="Wrap" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
