<Window x:Class="WPF_projo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moje Eventy" Height="720" Width="1020"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Grid Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="Moje Eventy" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="— Twój personalny terminarz wydarzeń" Foreground="White"
                           FontSize="14" VerticalAlignment="Center" Margin="10,2,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Lewa kolumna: filtry + lista -->
            <Grid Grid.Column="0" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tytuł + licznik -->
                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" Text="Wydarzenia" FontSize="20" FontWeight="SemiBold" Foreground="Black"/>
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="Black">
                        <Run Text="Łącznie: "/>
                        <Run Text="{Binding EventsCount, Mode=OneWay}"/>
                    </TextBlock>
                </DockPanel>

                <!-- Zakładki -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="Nadchodzące" IsChecked="{Binding IsUpcomingTab}"
                                 GroupName="MainTabs" Style="{StaticResource TabButton}"/>
                    <RadioButton Content="Historia" IsChecked="{Binding IsHistoryTab}"
                                 GroupName="MainTabs" Style="{StaticResource TabButton}"/>
                </StackPanel>

                <!-- Pasek filtrów -->
                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" VerticalContentAlignment="Center"
                                 ToolTip="Szukaj po tytule lub opisie"/>
                        <ComboBox Grid.Column="1" Width="130" Margin="8,0,0,0" Height="30"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"/>
                        <ComboBox Grid.Column="2" Width="130" Margin="8,0,0,0" Height="30"
                                  ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSort}"/>
                        <Button Grid.Column="3" Content="{Binding SortDirectionLabel}"
                                Margin="8,0,0,0" Height="30" Width="110"
                                Style="{StaticResource MutedButton}"
                                Command="{Binding ToggleSortDirectionCommand}"/>
                    </Grid>
                </Border>

                <!-- Lista -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding EventsView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="Black"/>
                                                <Border Background="#ECF0F1" Padding="8,2" Margin="10,2,0,0" VerticalAlignment="Center"
                                                        BorderBrush="#BDC3C7" BorderThickness="1">
                                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Black"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Date}" FontSize="13" Foreground="#555" Margin="0,4,0,2"/>
                                            <TextBlock Text="{Binding RatingText}" FontSize="13" Foreground="#E67E22" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding ShortDescription}" TextWrapping="Wrap" Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="95">
                                            <Button Content="Szczegóły" Height="32" Margin="0,0,0,5"
                                                    Style="{StaticResource WarningButton}"
                                                    Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Height="32" Margin="0,0,0,5"
                                                    Command="{Binding DataContext.ToggleAttendedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                        <Setter Property="Content" Value="Byłem/am"/>
                                                        <Setter Property="Background" Value="{StaticResource MutedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAttended}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                                <Setter Property="Content" Value="Byłem/am ✓"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="Usuń" Height="32"
                                                    Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Prawa kolumna: formularz -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,20,20,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Dodaj wydarzenie" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,0,20"/>

                    <TextBlock Text="Tytuł:" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="TitleErrSource" Text="{Binding NewEvent.Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="30" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TitleErrSource}"/>

                    <TextBlock Text="Data (dd.MM.yyyy):" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="DateErrSource" Text="{Binding NewEvent.Date, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="30" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DateErrSource}"/>

                    <TextBlock Text="Kategoria:" Foreground="Black" Margin="0,0,0,5"/>
                    <ComboBox Height="30" Margin="0,0,0,10"
                              ItemsSource="{Binding FormCategories}"
                              SelectedItem="{Binding NewEvent.Category}"/>

                    <TextBlock Text="Krótki opis:" Foreground="Black" Margin="0,0,0,5"/>
                    <TextBox x:Name="DescErrSource" Text="{Binding NewEvent.ShortDescription, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,2"/>
                    <TextBlock Foreground="#C0392B" FontSize="11" Margin="0,0,0,10"
                               Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DescErrSource}"/>

                    <Button Content="Dodaj" Height="40" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddEventCommand}" Margin="0,0,0,8"/>
                    <Button Content="Wyczyść" Height="32" Style="{StaticResource MutedButton}"
                            Command="{Binding ClearFormCommand}"/>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="Black"
                               TextWrapping="Wrap" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
